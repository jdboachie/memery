{
  "manifest_version": 3,
  "name": "Memery",
  "description": "Save highlights from anywhere on the web",
  "version": "0.0.0",
  "permissions": ["contextMenus", "tabs", "storage"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "Memry"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["dist/index.js"]
    }
  ]
}
