{
  "manifest_version": 2,
  "name": "Memery",
  "description": "Save highlights from anywhere on the web",
  "version": "0.0.0",
  "permissions": ["contextMenus", "tabs", "storage", "<all_urls>"],
  "background": {
    "scripts": ["dist/background.js"],
    "persistent": false,
    "type": "module"
  },
  "actions": {
    "default_popup": "dist/popup/popup.html",
    "default_title": "Memry"
  },
  "browser_action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "Memry"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["dist/index.js"]
    }
  ]
}
